# Storage mode: "local" (PGlite, default) or "cloud" (Supabase)
SESSIONGRAPH_STORAGE_MODE=local

# Required for cloud mode only:
# SESSIONGRAPH_SUPABASE_URL=https://your-project.supabase.co
# SESSIONGRAPH_SUPABASE_ANON_KEY=your-anon-key

# Ollama configuration (local mode)
# Defaults shown — uncomment to override
# SESSIONGRAPH_OLLAMA_URL=http://localhost:11434
# SESSIONGRAPH_OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
# SESSIONGRAPH_OLLAMA_CHAT_MODEL=qwen2.5:3b
