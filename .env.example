# Required: Supabase project credentials
SESSIONGRAPH_SUPABASE_URL=https://your-project.supabase.co
SESSIONGRAPH_SUPABASE_ANON_KEY=your-anon-key

# Optional: LLM for reasoning chain extraction (falls back to regex if not set)
SESSIONGRAPH_LLM_API_KEY=your-openai-api-key
SESSIONGRAPH_LLM_MODEL=gpt-4o-mini
SESSIONGRAPH_LLM_API_URL=https://api.openai.com/v1/chat/completions

# Alternative: OpenAI key (used if SESSIONGRAPH_LLM_API_KEY is not set)
# OPENAI_API_KEY=your-openai-api-key
